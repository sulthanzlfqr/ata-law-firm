# Sanity CMS - Public (aman di-expose ke browser)
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
# NEXT_PUBLIC_SANITY_API_VERSION tidak perlu diisi — sudah di-hardcode di sanity/env.ts

# Sanity CMS - Secret (JANGAN di-commit, isi di dashboard Vercel)
# Buat token baru di: https://sanity.io/manage → project → API → Tokens
# Permission yang dibutuhkan: Editor (untuk form kontak menulis pesanKontak)
SANITY_API_TOKEN=

# Secret untuk memverifikasi webhook Sanity di app/api/revalidate/route.ts
# Generate dengan: openssl rand -hex 32
# Harus sama persis dengan "Secret" yang diisi di sanity.io/manage saat
# membuat webhook, lihat instruksi setup webhook dari Claude.
SANITY_REVALIDATE_SECRET=
